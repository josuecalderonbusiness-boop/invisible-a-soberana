{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {"src": "/api/(.*)", "dest": "/api/$1"},
    {"src": "/vsl(.*)", "dest": "/public/vsl$1"},
    {"src": "/bienvenida(.*)", "dest": "/public/bienvenida$1"},
    {"src": "/", "dest": "/index.html"}
  ]
}
