{
  "version": 2,
  "rewrites": [
    {"source": "/api/:path*", "destination": "/api/:path*"},
    {"source": "/bienvenida/:path*", "destination": "/public/bienvenida/:path*"},
    {"source": "/vsl/:path*", "destination": "/public/vsl/:path*"},
    {"source": "/", "destination": "/index.html"}
  ]
}
